<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.plantdoctor.krishinoor">

    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Plant Doctor"
        android:theme="@style/Theme.Krishinoor"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:extractNativeLibs="true">

        <activity android:name="com.plantdoctor.krishinoor.SplashActivity" android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name="com.plantdoctor.krishinoor.LoginActivity" android:screenOrientation="portrait"/>
        <activity android:name="com.plantdoctor.krishinoor.MainActivity" android:screenOrientation="portrait"/>
        <activity android:name="com.plantdoctor.krishinoor.ScanActivity" android:screenOrientation="portrait"/>
        <activity android:name="com.plantdoctor.krishinoor.ResultActivity" android:screenOrientation="portrait"/>
        <activity android:name="com.plantdoctor.krishinoor.HistoryActivity" android:screenOrientation="portrait"/>
        <activity android:name="com.plantdoctor.krishinoor.RegisterActivity" android:screenOrientation="portrait"/>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

    </application>
</manifest>
