<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/good_morning"
                        android:textColor="@color/text_dark"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dateText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saturday, 28 Mar 2026"
                        android:textColor="@color/text_grey"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Monitoring Active"
                            android:textColor="@color/status_healthy"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Logout Button at Top Right -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/logoutBtn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/logout"
                    android:textColor="@color/status_diseased"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconSize="16dp"
                    app:iconTint="@color/status_diseased"/>
            </RelativeLayout>

            <!-- Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_scans"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/totalScansValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/text_dark"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scans"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/divider"
                        android:layout_gravity="center_vertical"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diseased"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/diseasedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4"
                            android:textColor="@color/status_diseased"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plants"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/divider"
                        android:layout_gravity="center_vertical"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/healthy"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/healthyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textColor="@color/status_healthy"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plants"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUICK ACTIONS"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanBtnQuick"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/new_scan"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/brand_forest_deep"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    android:layout_marginEnd="6dp"
                    android:textAllCaps="false"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/historyBtnQuick"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/history"
                    android:textColor="@color/brand_forest_deep"
                    app:strokeColor="@color/brand_forest_deep"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_recent_history"
                    android:layout_marginStart="6dp"
                    android:textAllCaps="false"/>
            </LinearLayout>

            <!-- Last Scan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/last_scan"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/recentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/recentPlantName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tomato"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/viewLastBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/view_more"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/recentDisease"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/recentPlantName"
                            android:layout_marginTop="4dp"
                            android:text="⚠️ Late Blight detected"
                            android:textColor="@color/status_diseased"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/recentGps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 20.2961, 85.8245"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/recentTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="9:14 AM"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/noScanText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No scans recorded yet.\nStart by scanning a leaf!"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/scanFab"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:text="@string/scan_plant"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        app:backgroundTint="@color/brand_forest_deep"
        app:cornerRadius="16dp"
        android:textAllCaps="false"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
