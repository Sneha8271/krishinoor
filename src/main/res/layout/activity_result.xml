<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:layout_marginTop="32dp">

            <TextView
                android:id="@+id/backBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="@color/text_dark"
                android:textSize="24sp"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Analysis Result"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <!-- Result Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/previewImage"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src=" @drawable/dot_red"
                            android:scaleType="centerInside"
                            android:layout_marginBottom="16dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/plantNameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tomato"
                                android:textColor="@color/text_dark"
                                android:textSize="22sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/statusBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="DISEASED"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:background="@drawable/badge_bg"
                                android:backgroundTint="@color/status_diseased"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/diseaseText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚠️ Late Blight"
                            android:textColor="@color/status_diseased"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/confidenceText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Confidence: 94.2%"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>

                        <ProgressBar
                            android:id="@+id/confidenceBar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="12dp"
                            android:progress="94"
                            android:progressTint="@color/status_healthy"
                            android:progressBackgroundTint="#F0F0F0"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginTop="24dp"
                            android:layout_marginBottom="24dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="LOCATION &amp; TIME"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/gpsText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📍 20.29614, 85.82453"
                            android:textColor="@color/sky_blue"
                            android:textSize="13sp"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:id="@+id/gridText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🗺️ N20.50 / E85.82"
                            android:textColor="@color/sky_blue"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/timeText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🗓️ 2026-03-28 09:14:22"
                            android:textColor="@color/text_grey"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginTop="24dp"
                            android:layout_marginBottom="24dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="TREATMENT &amp; SOLUTION"
                            android:textColor="@color/text_grey"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/solutionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Remove infected tissue immediately. Apply copper-based fungicide weekly. Avoid overhead irrigation."
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:id="@+id/statusIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/newScanBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="20dp"
            android:text="New Scan"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_forest_deep"
            app:cornerRadius="14dp"
            android:textAllCaps="false"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
